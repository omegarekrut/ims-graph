{
  "name": "ims-graph",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run build:widget && bun run build:site && bun run build:codepen && bun run build:pages",
    "build:widget": "vite build --mode widget-single && vite build --mode widget-scene && bun run scripts/publish-widget-aliases.ts",
    "build:site": "vite build --mode site",
    "build:codepen": "bun run scripts/render-codepen.ts",
    "build:pages": "bun run scripts/prepare-pages.ts",
    "sync:codepen": "bun run scripts/codepen-sync.ts",
    "format": "biome format --write .",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:e2e": "bunx playwright test --config=playwright.config.ts",
    "test": "bun run test:unit && bun run test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.3.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
